# Example environment variables
# Copie este arquivo para .env.local e preencha com seus valores

# API Configuration
VITE_API_URL=https://api.example.com
VITE_API_TIMEOUT=10000

# Contact Information
VITE_CONTACT_EMAIL=seu.email@example.com
VITE_CONTACT_PHONE=+55 (11) 99999-9999

# Analytics (opcional)
VITE_GA_ID=UA-XXXXXXXXX-X

# Feature Flags
VITE_ENABLE_BLOG=false
VITE_ENABLE_SHOP=false
